<UserControl x:Class="DailyBudgetWPF.Vistas.Categorias"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" d:DesignHeight="850" d:DesignWidth="1000"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <UserControl.Resources>
        <Style x:Key="EstiloBotaoEmoji" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource CorTexto}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#20FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer x:Name="scrMain" VerticalScrollBarVisibility="Auto" ScrollChanged="scrMain_ScrollChanged">
        <Grid Background="Transparent" Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho Premium -->
            <Border CornerRadius="22" Margin="0,0,0,25" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A9B59B6" Offset="0"/>
                        <GradientStop Color="#0D6C5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#9B59B6" Offset="0"/>
                        <GradientStop Color="#6C5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid Margin="30,22">
                     <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏷️ Categorias" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource CorTexto}"/>
                            <ToggleButton x:Name="btnAjudaCategorias" Style="{DynamicResource EstiloBotaoAjuda}" Margin="12,0,0,0"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaCategorias}" StaysOpen="False" AllowsTransparency="True"
                                   PlacementTarget="{Binding ElementName=btnAjudaCategorias}" Placement="Bottom">
                                <Border Background="#201525" BorderBrush="#9B59B6" BorderThickness="1.5" CornerRadius="14" Padding="18,14" MaxWidth="300">
                                    <Border.Effect><DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="🏷️ Categorias" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="#D5C0DF" FontSize="12.5" LineHeight="20">
                                            As categorias servem para agrupar e organizar as tuas despesas por temas (Ex: Alimentação, Transportes).
                                            Cria novas categorias escolhendo um Nome, Emoji e Cor. Podes também definir limites mensais (orçamentos) para cada uma.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                        <TextBlock Text="Organiza os teus gastos por temas e define orçamentos mensais" Foreground="{DynamicResource CorTextoSec}" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>
                    <TextBlock Text="📁" FontSize="40" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" Opacity="0.12"/>
                </Grid>
            </Border>

            <!-- Formulário Nova Categoria -->
            <Border Grid.Row="1" Background="{DynamicResource CorCard}" Padding="25" CornerRadius="25" Margin="0,0,0,20" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,20,0">
                        <TextBlock Text="NOME DA CATEGORIA" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                        <TextBox Style="{DynamicResource EstiloInput}" x:Name="txtNomeCategoria" Height="45"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,20,0">
                        <TextBlock Text="EMOJI" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                        <!-- Botão que abre popup de emojis -->
                        <Button x:Name="btnAbrirEmojis" Height="45" Click="btnAbrirEmojis_Click" Style="{DynamicResource EstiloBotaoColorPicker}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="txtEmojiSelecionado" Text="💰" FontFamily="Segoe UI Emoji" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="▼" Foreground="{DynamicResource CorTextoSec}" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </Grid>
                        </Button>
                        <!-- Popup grelha de emojis -->
                        <Popup x:Name="popEmojis" AllowsTransparency="True" StaysOpen="False" Placement="Bottom" VerticalOffset="4" PlacementTarget="{Binding ElementName=btnAbrirEmojis}">
                            <Border Background="{DynamicResource CorCard}" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5" CornerRadius="16" Padding="10" MaxWidth="260">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.6" ShadowDepth="4"/>
                                </Border.Effect>
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="280">
                                    <WrapPanel x:Name="wpEmojis" Orientation="Horizontal" MaxWidth="240"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,20,0">
                        <TextBlock Text="COR" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                        <!-- Botão Seletor de Cor - só mostra emoji paleta + círculo de cor -->
                        <Button x:Name="btnAbrirColorPicker" Height="45" Click="btnAbrirColorPicker_Click" Style="{DynamicResource EstiloBotaoColorPicker}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Emoji de palete -->
                                <TextBlock Text="🎨" FontFamily="Segoe UI Emoji" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <!-- Círculo de Cor (sem texto hex) -->
                                <Border x:Name="brdCorSelecionada" Grid.Column="1" Width="22" Height="22" CornerRadius="11" Background="#2ECC71" BorderBrush="#50FFFFFF" BorderThickness="1.5" HorizontalAlignment="Center"/>
                                <!-- Texto hex oculto, mantido apenas para uso interno no código -->
                                <TextBlock x:Name="txtHexSelecionado" Visibility="Collapsed" Text="#2ECC71"/>
                                <TextBlock Grid.Column="2" Text="▼" Foreground="{DynamicResource CorTextoSec}" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </Grid>
                        </Button>
                        <!-- O Popup com o Color Picker HSV -->
                        <Popup x:Name="popColorPicker" AllowsTransparency="True" StaysOpen="True" Placement="Bottom" PlacementTarget="{Binding ElementName=btnAbrirColorPicker}">
                            <Border Background="{DynamicResource CorCard}" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5" CornerRadius="16" Width="220" Padding="15" Margin="0,4,0,0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="15" Color="#000000" Opacity="0.5" ShadowDepth="3"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Saturation/Value Canvas -->
                                    <Border x:Name="brdColorCanvas" Height="120" CornerRadius="8" ClipToBounds="True" MouseLeftButtonDown="brdColorCanvas_MouseLeftButtonDown" MouseMove="brdColorCanvas_MouseMove" MouseLeftButtonUp="brdColorCanvas_MouseLeftButtonUp" Cursor="Cross" Background="Transparent">
                                        <Grid>
                                            <!-- Hue Base Layer -->
                                            <Border x:Name="brdCanvasHueBase" Background="#FF0000"/>
                                            <!-- White to Transparent Horizontal Layer -->
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- Transparent to Black Vertical Layer -->
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#00000000" Offset="0"/>
                                                        <GradientStop Color="#FF000000" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                            </Border>
                                            <!-- Selector Indicator (little circle) -->
                                            <Canvas>
                                                <Ellipse x:Name="elpCanvasSelector" Width="10" Height="10" Stroke="White" StrokeThickness="1.5" Fill="Transparent" Margin="-5,-5,0,0"/>
                                            </Canvas>
                                        </Grid>
                                    </Border>
                                    <!-- Hue Slider -->
                                    <TextBlock Text="TONALIDADE" Foreground="{DynamicResource CorTextoSec}" FontSize="9" FontWeight="Black" Margin="0,10,0,4"/>
                                    <Slider x:Name="sldHue" Minimum="0" Maximum="360" Value="120" ValueChanged="sldHue_ValueChanged" Style="{DynamicResource EstiloHueSlider}"/>
                                    
                                    <!-- Rodapé com Preview e Botão -->
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="brdPreviewColor" Width="28" Height="28" CornerRadius="14" BorderBrush="#30FFFFFF" BorderThickness="1" Background="#2ECC71"/>
                                        <TextBox x:Name="txtHexPreview" Grid.Column="1" Text="#2ECC71" Foreground="{DynamicResource CorTexto}" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" Margin="8,0" FontWeight="Bold" IsReadOnly="True"/>
                                        <Button Grid.Column="2" Content="Ok" Style="{DynamicResource EstiloBotao}" Padding="12,0" Height="28" Click="btnConfirmarCor_Click"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <Button x:Name="btnAdicionarCategoria" Grid.Column="3" Content="ADICIONAR" Style="{DynamicResource EstiloBotao}" Padding="30,0" Height="45" VerticalAlignment="Bottom" Click="btnAdicionarCategoria_Click"/>
                </Grid>
            </Border>

            <!-- Lista de categorias existentes -->
            <Border Grid.Row="2" Background="{DynamicResource CorCard}" CornerRadius="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5" Padding="20" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="CATEGORIAS EXISTENTES" Foreground="{DynamicResource CorTextoSec}" FontSize="11" FontWeight="Black" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icCategorias">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="180" Height="80" Background="{DynamicResource CorFundo}" CornerRadius="18" Margin="0,0,12,12" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1">
                                    <Grid Margin="15">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="45" Height="45" Background="{Binding CorBrush}" Opacity="0.15" CornerRadius="12"/>
                                        <TextBlock Text="{Binding Emoji}" FontFamily="Segoe UI Emoji" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nome}" Foreground="{DynamicResource CorTexto}" FontWeight="Bold" FontSize="14" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        <Button Grid.Column="2" Content="✕" Click="btnRemoverCategoria_Click" Tag="{Binding Id}" Background="Transparent" Foreground="{DynamicResource CorTextoSec}" BorderThickness="0" Padding="5" Cursor="Hand"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Secção: Orçamentos Mensais -->
            <Border Grid.Row="3" Background="{DynamicResource CorCard}" Padding="25" CornerRadius="25" Margin="0,0,0,20" BorderBrush="#2ECC71" BorderThickness="1.5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                     <StackPanel Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="💡 DEFINIR ORÇAMENTO MENSAL" Foreground="#2ECC71" FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="btnAjudaLimites" Style="{DynamicResource EstiloBotaoAjuda}" Margin="8,0,0,0"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaLimites}" StaysOpen="False" AllowsTransparency="True"
                                   PlacementTarget="{Binding ElementName=btnAjudaLimites}" Placement="Bottom">
                                <Border Background="#15241B" BorderBrush="#2ECC71" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="280">
                                    <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                    <TextBlock TextWrapping="Wrap" Foreground="#B0CFBA" FontSize="12.5" LineHeight="20">
                                        Limita o quanto queres gastar numa categoria este mês.
                                        Se a soma das tuas despesas nessa categoria ultrapassar 80% do limite, a aplicação avisa-te com um alerta na página inicial!
                                    </TextBlock>
                                </Border>
                            </Popup>
                        </StackPanel>
                        <TextBlock Text="Define um limite de gasto mensal por categoria. Será alertado quando ultrapassar 80%." Foreground="{DynamicResource CorTextoSec}" FontSize="12" TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,15,0">
                            <TextBlock Text="CATEGORIA" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="0,0,0,6"/>
                            <ComboBox x:Name="cbCatOrcamento" Style="{DynamicResource EstiloCombo}" Width="160" Height="40"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="LIMITE (€/mês)" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="0,0,0,6"/>
                            <TextBox x:Name="txtLimiteMensal" Style="{DynamicResource EstiloInput}" Width="110" Height="40" TextAlignment="Right" LostFocus="txtLimiteMensal_LostFocus"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="2" Content="DEFINIR" Style="{DynamicResource EstiloBotao}"
                            Height="40" Padding="20,0" VerticalAlignment="Bottom"
                            Click="btnDefinirOrcamento_Click"/>
                </Grid>
            </Border>

            <!-- Lista de orçamentos definidos -->
            <Border Grid.Row="4" Background="{DynamicResource CorCard}" CornerRadius="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5" Padding="20">
                <StackPanel>
                    <TextBlock Text="ORÇAMENTOS MENSAIS DEFINIDOS" Foreground="{DynamicResource CorTextoSec}" FontSize="11" FontWeight="Black" Margin="0,0,0,15"/>
                    <ItemsControl x:Name="icOrcamentos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Background="{DynamicResource CorFundo}" CornerRadius="14"
                                        Margin="0,0,12,12" BorderBrush="{Binding CorEstado}" BorderThickness="1.5" Padding="15">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{DynamicResource CorTexto}" FontWeight="Bold" FontSize="14">
                                                <Run Text="{Binding EmojiCategoria}"/>
                                                <Run Text=" "/>
                                                <Run Text="{Binding NomeCategoria}"/>
                                            </TextBlock>
                                            <Button Content="✕" Grid.Column="1" HorizontalAlignment="Right"
                                                    Background="Transparent" Foreground="{DynamicResource CorTextoSec}"
                                                    BorderThickness="0" Cursor="Hand" Tag="{Binding Id}"
                                                    Click="btnRemoverOrcamento_Click"/>
                                        </Grid>
                                        <ProgressBar Value="{Binding Percentagem, Mode=OneWay}" Maximum="100" Height="8"
                                                     Foreground="{Binding CorEstado}" Background="#1A1A2E"
                                                     BorderThickness="0" Margin="0,0,0,5"/>
                                        <TextBlock Text="{Binding TextoEstado}" Foreground="{Binding CorEstado}"
                                                   FontSize="11" FontWeight="SemiBold" Margin="0,0,0,3"/>
                                        <TextBlock Foreground="{DynamicResource CorTextoSec}" FontSize="11">
                                            <Run Text="{Binding GastoMesAtual, StringFormat={}{0:N2} €}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding LimiteMensal, StringFormat={}{0:N2} €}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
