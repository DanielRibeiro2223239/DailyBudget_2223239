<UserControl x:Class="DailyBudgetWPF.Vistas.Relatorios"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="Transparent" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho gradiente -->
            <Border CornerRadius="22" Margin="0,0,0,25" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A3498DB" Offset="0"/>
                        <GradientStop Color="#0D2980B9" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#3498DB" Offset="0"/>
                        <GradientStop Color="#2980B9" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid Margin="30,22">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂 Análise Financeira" FontSize="30" FontWeight="Bold"
                                       Foreground="{DynamicResource CorTexto}"/>
                            <ToggleButton x:Name="btnAjudaRelatorios" Style="{DynamicResource EstiloBotaoAjuda}" Margin="12,0,0,0"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaRelatorios}" StaysOpen="False" AllowsTransparency="True"
                                   PlacementTarget="{Binding ElementName=btnAjudaRelatorios}" Placement="Bottom">
                                <Border Background="#141824" BorderBrush="#3498DB" BorderThickness="1.5" CornerRadius="14" Padding="18,14" MaxWidth="300">
                                    <Border.Effect><DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="📂 Análise Financeira" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="#B0C0D8" FontSize="12.5" LineHeight="20">
                                            Vê gráficos e mensagens inteligentes baseadas nos teus dados financeiros.
                                            As mensagens são personalizadas com base nos teus gastos, receitas, orçamentos e desejos.
                                            Exporta os teus dados para Excel com o botão 📄 EXCEL.
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>

                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <Button x:Name="btnChartBar"  Content="📊" Style="{DynamicResource EstiloBotao}"
                                    Padding="10,5" Click="btnSetChart_Click" Tag="0" Margin="0,0,5,0" ToolTip="Barras"/>
                            <Button x:Name="btnChartLine" Content="📈" Style="{DynamicResource EstiloBotao}"
                                    Background="#34495E" Padding="10,5" Click="btnSetChart_Click" Tag="1"
                                    Margin="0,0,5,0" ToolTip="Linhas"/>
                            <Button x:Name="btnChartPie"  Content="🍩" Style="{DynamicResource EstiloBotao}"
                                    Background="#34495E" Padding="10,5" Click="btnSetChart_Click" Tag="2"
                                    ToolTip="Por Categoria"/>
                        </StackPanel>
                        <Button x:Name="btnExportar" Content="📄 EXCEL" Style="{DynamicResource EstiloBotao}"
                                Click="btnExportar_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Área do gráfico -->
            <Border Grid.Row="1" Background="{DynamicResource CorCard}" CornerRadius="25" Padding="30"
                    BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5" Margin="0,0,0,25">
                <Grid MinHeight="220">
                    <lvc:CartesianChart x:Name="chartRelatorio" LegendLocation="Bottom" Hoverable="False"
                                        Foreground="{DynamicResource CorTexto}">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis x:Name="axisX" Foreground="{DynamicResource CorTextoSec}" ShowLabels="True"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Valor (€)" Foreground="{DynamicResource CorTextoSec}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                    <lvc:PieChart x:Name="chartPie" Visibility="Collapsed"
                                  LegendLocation="Right" InnerRadius="50" Hoverable="False"
                                  Foreground="{DynamicResource CorTexto}"/>
                    <TextBlock x:Name="txtSemDados" Text="Sem transações para apresentar. Adiciona receitas e despesas primeiro."
                               Foreground="{DynamicResource CorTextoSec}" FontSize="16"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap"
                               Visibility="Collapsed"/>
                </Grid>
            </Border>

            <!-- Cards KPI -->
            <UniformGrid Grid.Row="2" Rows="1" Columns="3" Margin="0,0,0,25">
                <!-- Estado da Conta -->
                <Border Background="{DynamicResource CorCard}" Margin="0,0,15,0" CornerRadius="20"
                        Padding="22" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="🏦" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="ESTADO DA CONTA" FontSize="11" FontWeight="Black"
                                       Foreground="{DynamicResource CorTextoSec}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtEstadoConta" Text="---" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource CorTexto}" Margin="0,0,0,10"/>
                        <ProgressBar x:Name="pbSaude" Height="6" Maximum="100" Value="0"
                                     BorderThickness="0" Background="#1A1A2E"/>
                        <TextBlock Text="Índice de saúde financeira" Foreground="{DynamicResource CorTextoSec}"
                                   FontSize="10" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Poupança -->
                <Border Background="{DynamicResource CorCard}" Margin="0,0,15,0" CornerRadius="20"
                        Padding="22" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="💎" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="POUPANÇA" FontSize="11" FontWeight="Black"
                                       Foreground="{DynamicResource CorTextoSec}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtStatusPoupanca" Text="---" FontSize="22" FontWeight="Bold"
                                   Foreground="#2ECC71" Margin="0,0,0,10"/>
                        <TextBlock x:Name="txtValorBalanco" Text="Balanço total"
                                   Foreground="{DynamicResource CorTextoSec}" FontSize="10"/>
                    </StackPanel>
                </Border>

                <!-- Maior Gasto -->
                <Border Background="{DynamicResource CorCard}" CornerRadius="20"
                        Padding="22" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="🔥" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="MAIOR GASTO" FontSize="11" FontWeight="Black"
                                       Foreground="{DynamicResource CorTextoSec}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="txtMaiorGasto" Text="---" FontSize="22" FontWeight="Bold"
                                   Foreground="#E74C3C" Margin="0,0,0,10"/>
                        <TextBlock Text="Categoria com mais despesas"
                                   Foreground="{DynamicResource CorTextoSec}" FontSize="10"/>
                    </StackPanel>
                </Border>
            </UniformGrid>


        </Grid>
    </ScrollViewer>
</UserControl>
