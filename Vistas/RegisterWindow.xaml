<Window x:Class="DailyBudgetWPF.Vistas.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DailyBudget - Nova Conta" Height="650" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="PulseGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="glowOrb1" Storyboard.TargetProperty="Opacity"
                             From="0.06" To="0.14" Duration="0:0:3"/>
            <DoubleAnimation Storyboard.TargetName="glowOrb2" Storyboard.TargetProperty="Opacity"
                             From="0.04" To="0.10" Duration="0:0:4"/>
        </Storyboard>
        <Storyboard x:Key="FormFadeIn">
            <DoubleAnimation Storyboard.TargetName="formPanel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="formPanel" Storyboard.TargetProperty="Margin"
                                From="60,20,40,20" To="40,20,40,20" Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <!-- Show/Hide Password Toggle Style -->
        <Style x:Key="EstiloBotaoRevelarSenha" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="10">
                            <TextBlock x:Name="txtIcon" Text="👁️" FontSize="14" Foreground="#80988EB3" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="txtIcon" Property="Text" Value="🙈"/>
                                <Setter TargetName="txtIcon" Property="Foreground" Value="#6C5CE7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txtIcon" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseGlow}"/>
            <BeginStoryboard Storyboard="{StaticResource FormFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Border CornerRadius="22" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="#000000" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0A0D0A" Offset="0"/>
                <GradientStop Color="#111611" Offset="0.5"/>
                <GradientStop Color="#0D100D" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT: HERO PANEL (Indigo/Purple) ═══ -->
            <Border Grid.Column="0" MouseLeftButtonDown="Hero_MouseLeftButtonDown" Cursor="SizeAll" CornerRadius="22,0,0,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A0F3C" Offset="0"/>
                        <GradientStop Color="#4834A8" Offset="0.3"/>
                        <GradientStop Color="#6C5CE7" Offset="0.65"/>
                        <GradientStop Color="#a29bfe" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse x:Name="glowOrb1" Width="380" Height="380" Opacity="0.06"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-120,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse x:Name="glowOrb2" Width="260" Height="260" Opacity="0.04"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-100">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#FFFFFF" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Grid pattern -->
                    <Border Opacity="0.03">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,30,30" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen><Pen Brush="White" Thickness="0.5"/></GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,30,30"/></GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="35,0">
                        <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                                    <GradientStop Color="#0CFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.18"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" Color="#000000" Opacity="0.25" ShadowDepth="0"/>
                            </Border.Effect>
                            <!-- Wallet icon -->
                            <Viewbox Width="32" Height="32">
                                <Canvas Width="24" Height="24">
                                    <!-- Card body -->
                                    <Rectangle Canvas.Left="1" Canvas.Top="5" Width="22" Height="14"
                                               RadiusX="2" RadiusY="2" Fill="White" Opacity="0.45"/>
                                    <!-- Card stripe -->
                                    <Rectangle Canvas.Left="1" Canvas.Top="9" Width="22" Height="3"
                                               Fill="White" Opacity="0.80"/>
                                    <!-- Coin dot -->
                                    <Ellipse Canvas.Left="14.5" Canvas.Top="13" Width="4" Height="4"
                                             Fill="White"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <TextBlock Text="Criar Conta" Foreground="White" FontSize="34" FontWeight="Black" HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect BlurRadius="16" Color="#000000" Opacity="0.3" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Começa a controlar o teu dinheiro hoje" Foreground="#D8FFFFFF" FontSize="13.5"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    </StackPanel>


                </Grid>
            </Border>

            <!-- ═══ RIGHT: REGISTER FORM ═══ -->
            <Grid x:Name="formPanel" Grid.Column="1" Margin="40,20,40,20" Opacity="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,-15,0">
                    <Button Content="─" Style="{DynamicResource EstiloTitleBar}" Foreground="#8E9E8E" Click="Minimize_Click"/>
                    <Button Content="✕" Style="{DynamicResource EstiloTitleBar}" Foreground="#8E9E8E" Click="Close_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,5,0,0">
                    <StackPanel>
                        <!-- Error panel -->
                        <Border x:Name="pnlErro" Visibility="Collapsed" CornerRadius="14" Padding="16,12" Margin="0,0,0,14" BorderThickness="1">
                            <Border.Background><SolidColorBrush Color="#E74C3C" Opacity="0.08"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#E74C3C" Opacity="0.25"/></Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,10,0">
                                    <Border.Background><SolidColorBrush Color="#E74C3C" Opacity="0.15"/></Border.Background>
                                    <TextBlock Text="!" Foreground="#E74C3C" FontSize="14" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="txtErro" Foreground="#F07070" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Success panel -->
                        <Border x:Name="pnlSucesso" Visibility="Collapsed" CornerRadius="14" Padding="16,12" Margin="0,0,0,14" BorderThickness="1">
                            <Border.Background><SolidColorBrush Color="#2ECC71" Opacity="0.08"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#2ECC71" Opacity="0.25"/></Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,10,0">
                                    <Border.Background><SolidColorBrush Color="#2ECC71" Opacity="0.15"/></Border.Background>
                                    <TextBlock Text="✓" Foreground="#2ECC71" FontSize="14" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="txtSucesso" Foreground="#5BDB8A" FontSize="13" TextWrapping="Wrap" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Header -->
                        <TextBlock Foreground="White" FontSize="24" FontWeight="Black" Margin="0,0,0,20" Text="Novo por aqui?"/>

                        <!-- NOME -->
                        <TextBlock Text="NOME COMPLETO" Foreground="#988EB3" FontSize="10.5" FontWeight="Black" Margin="6,0,0,6"/>
                        <Border x:Name="borderNome" Background="#07FFFFFF" CornerRadius="14" Height="46" Margin="0,0,0,14" BorderThickness="1.5">
                            <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.08"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✍" FontSize="16" Foreground="#988EB3" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                <TextBox Grid.Column="1" x:Name="txtNome" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource CorTexto}" Padding="5,0,15,0" VerticalContentAlignment="Center"
                                         FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderNome"/>
                            </Grid>
                        </Border>

                        <!-- USERNAME -->
                        <TextBlock Text="NOME DE UTILIZADOR" Foreground="#988EB3" FontSize="10.5" FontWeight="Black" Margin="6,0,0,6"/>
                        <Border x:Name="borderUsername" Background="#07FFFFFF" CornerRadius="14" Height="46" Margin="0,0,0,14" BorderThickness="1.5">
                            <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.08"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="👤" FontSize="15" Foreground="#988EB3" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                <TextBox Grid.Column="1" x:Name="txtUsername" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource CorTexto}" Padding="5,0,15,0" VerticalContentAlignment="Center"
                                         FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                         PreviewKeyDown="txtUsername_PreviewKeyDown" TextChanged="txtUsername_TextChanged"
                                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderUsername"/>
                            </Grid>
                        </Border>

                        <!-- EMAIL -->
                        <TextBlock Text="E-MAIL" Foreground="#988EB3" FontSize="10.5" FontWeight="Black" Margin="6,0,0,6"/>
                        <Border x:Name="borderEmail" Background="#07FFFFFF" CornerRadius="14" Height="46" Margin="0,0,0,14" BorderThickness="1.5">
                            <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.08"/></Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✉" FontSize="16" Foreground="#988EB3" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                <TextBox Grid.Column="1" x:Name="txtEmail" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource CorTexto}" Padding="5,0,15,0" VerticalContentAlignment="Center"
                                         FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderEmail"/>
                            </Grid>
                        </Border>

                        <!-- PASSWORDS side-by-side -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="PALAVRA-PASSE" Foreground="#988EB3" FontSize="10.5" FontWeight="Black" Margin="6,0,0,6"/>
                                <Border x:Name="borderPass" Background="#07FFFFFF" CornerRadius="14" Height="46" Margin="0,0,0,14" BorderThickness="1.5">
                                    <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.08"/></Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔑" FontSize="15" Foreground="#988EB3" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                        <PasswordBox Grid.Column="1" x:Name="txtPassword" Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource CorTexto}" Padding="5,0,5,0" VerticalContentAlignment="Center"
                                                     FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                                     GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderPass" PasswordChanged="txtPassword_PasswordChanged"/>
                                        <TextBox Grid.Column="1" x:Name="txtPasswordUnmasked" Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource CorTexto}" Padding="5,0,5,0" VerticalContentAlignment="Center"
                                                 FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                                 GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderPass" Visibility="Collapsed" TextChanged="txtPasswordUnmasked_TextChanged"/>
                                        <ToggleButton Grid.Column="2" x:Name="btnShowPassword" Click="btnShowPassword_Click" Style="{StaticResource EstiloBotaoRevelarSenha}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="CONFIRMAR" Foreground="#988EB3" FontSize="10.5" FontWeight="Black" Margin="6,0,0,6"/>
                                <Border x:Name="borderConfirm" Background="#07FFFFFF" CornerRadius="14" Height="46" Margin="0,0,0,14" BorderThickness="1.5">
                                    <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.08"/></Border.BorderBrush>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="42"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="🔑" FontSize="15" Foreground="#988EB3" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                        <PasswordBox Grid.Column="1" x:Name="txtConfirmPassword" Background="Transparent" BorderThickness="0"
                                                     Foreground="{DynamicResource CorTexto}" Padding="5,0,5,0" VerticalContentAlignment="Center"
                                                     FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                                     GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderConfirm" PasswordChanged="txtConfirmPassword_PasswordChanged"/>
                                        <TextBox Grid.Column="1" x:Name="txtConfirmPasswordUnmasked" Background="Transparent" BorderThickness="0"
                                                 Foreground="{DynamicResource CorTexto}" Padding="5,0,5,0" VerticalContentAlignment="Center"
                                                 FontSize="14" CaretBrush="{DynamicResource CorDestaque}"
                                                 GotFocus="Input_GotFocus" LostFocus="Input_LostFocus" Tag="borderConfirm" Visibility="Collapsed" TextChanged="txtConfirmPasswordUnmasked_TextChanged"/>
                                        <ToggleButton Grid.Column="2" x:Name="btnShowConfirmPassword" Click="btnShowConfirmPassword_Click" Style="{StaticResource EstiloBotaoRevelarSenha}"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <!-- Register button -->
                        <Button x:Name="btnRegistar" Height="50" FontSize="15" Click="Register_Click" Cursor="Hand"
                                BorderThickness="0" Foreground="White" Margin="0,6,0,18" FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#5B4BD5" Offset="0"/>
                                                <GradientStop Color="#6C5CE7" Offset="0.5"/>
                                                <GradientStop Color="#a29bfe" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Color="#6C5CE7" Opacity="0.3" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <TextBlock Text="CRIAR CONTA" FontSize="14.5" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#6B5BE0" Offset="0"/>
                                                        <GradientStop Color="#7D6FF0" Offset="0.5"/>
                                                        <GradientStop Color="#b3adfe" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="btnBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="28" Color="#6C5CE7" Opacity="0.45" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBorder" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="btnBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Login link -->
                        <Border CornerRadius="14" Padding="16,12" BorderThickness="1">
                            <Border.Background><SolidColorBrush Color="#FFFFFF" Opacity="0.03"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush Color="#FFFFFF" Opacity="0.05"/></Border.BorderBrush>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="Já tens uma conta?" Foreground="#988EB3" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                                <Button Content="Iniciar sessão →" Background="Transparent" BorderThickness="0"
                                        Foreground="#a29bfe" FontWeight="Bold" FontSize="14" Click="Back_Click" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
