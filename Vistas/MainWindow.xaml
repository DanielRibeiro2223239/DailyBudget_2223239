<Window x:Class="DailyBudgetWPF.Vistas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DailyBudget - Login" Height="620" Width="900"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Animated gradient storyboard for hero panel -->
        <Storyboard x:Key="PulseGlow" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="glowOrb1" Storyboard.TargetProperty="Opacity"
                             From="0.06" To="0.14" Duration="0:0:3"/>
            <DoubleAnimation Storyboard.TargetName="glowOrb2" Storyboard.TargetProperty="Opacity"
                             From="0.04" To="0.10" Duration="0:0:4"/>
            <DoubleAnimation Storyboard.TargetName="glowOrb3" Storyboard.TargetProperty="Opacity"
                             From="0.05" To="0.12" Duration="0:0:2.5"/>
        </Storyboard>
        <!-- Fade-in for form panel -->
        <Storyboard x:Key="FormFadeIn">
            <DoubleAnimation Storyboard.TargetName="formPanel" Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <ThicknessAnimation Storyboard.TargetName="formPanel" Storyboard.TargetProperty="Margin"
                                From="60,25,40,25" To="44,25,40,25" Duration="0:0:0.5">
                <ThicknessAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
        <!-- Show/Hide Password Toggle Style -->
        <Style x:Key="EstiloBotaoRevelarSenha" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="10">
                            <TextBlock x:Name="txtIcon" Text="👁️" FontSize="14" Foreground="#808E9E8E" 
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="txtIcon" Property="Text" Value="🙈"/>
                                <Setter TargetName="txtIcon" Property="Foreground" Value="#2ECC71"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="txtIcon" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Custom Glassmorphic Google Button Style -->
        <Style x:Key="EstiloGoogle" TargetType="Button">
            <Setter Property="Background" Value="#09FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="18" Height="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <Canvas Width="48" Height="48">
                                        <Path Fill="#EA4335" Data="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                        <Path Fill="#4285F4" Data="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                                        <Path Fill="#FBBC05" Data="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                                        <Path Fill="#34A853" Data="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="{TemplateBinding Content}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#40FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="border" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PulseGlow}"/>
            <BeginStoryboard Storyboard="{StaticResource FormFadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- Drop shadow for entire window -->
    <Border CornerRadius="22" ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="40" Color="#000000" Opacity="0.45" ShadowDepth="0"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#0A0D0A" Offset="0"/>
                <GradientStop Color="#111611" Offset="0.5"/>
                <GradientStop Color="#0D100D" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <!-- Left Banner Pane -->
                <ColumnDefinition Width="370"/>
                <!-- Right Form Pane -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT PANEL: PREMIUM HERO BRAND (370px) ═══ -->
            <Border Grid.Column="0" MouseLeftButtonDown="Hero_MouseLeftButtonDown" Cursor="SizeAll" CornerRadius="22,0,0,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#071A0E" Offset="0"/>
                        <GradientStop Color="#0D3320" Offset="0.45"/>
                        <GradientStop Color="#145C35" Offset="0.75"/>
                        <GradientStop Color="#1A7A44" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <!-- Subtle ambient orbs -->
                    <Ellipse x:Name="glowOrb1" Width="320" Height="320" Opacity="0.06"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-90,-90,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#4ADE80" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse x:Name="glowOrb2" Width="200" Height="200" Opacity="0.05"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-60,0,0,-80">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#22C55E" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Ellipse x:Name="glowOrb3" Width="100" Height="100" Opacity="0.04"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="30,60,0,0">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#86EFAC" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>

                    <!-- Subtle dot pattern overlay -->
                    <Border Opacity="0.025">
                        <Border.Background>
                            <DrawingBrush TileMode="Tile" Viewport="0,0,20,20" ViewportUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing Brush="White">
                                        <GeometryDrawing.Geometry>
                                            <EllipseGeometry Center="2,2" RadiusX="1" RadiusY="1"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.Background>
                    </Border>

                    <!-- Main Brand Info -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40,0">

                        <!-- Logo mark: clean geometric icon -->
                        <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,22">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#30FFFFFF" Offset="0"/>
                                    <GradientStop Color="#0CFFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.18"/>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="24" Color="#000000" Opacity="0.25" ShadowDepth="0"/>
                            </Border.Effect>
                            <!-- Wallet icon (valid WPF XAML) -->
                            <Viewbox Width="32" Height="32">
                                <Canvas Width="24" Height="24">
                                    <!-- Card body -->
                                    <Rectangle Canvas.Left="1" Canvas.Top="5" Width="22" Height="14"
                                               RadiusX="2" RadiusY="2" Fill="White" Opacity="0.45"/>
                                    <!-- Card stripe -->
                                    <Rectangle Canvas.Left="1" Canvas.Top="9" Width="22" Height="3"
                                               Fill="White" Opacity="0.80"/>
                                    <!-- Coin dot -->
                                    <Ellipse Canvas.Left="14.5" Canvas.Top="13" Width="4" Height="4"
                                             Fill="White"/>
                                </Canvas>
                            </Viewbox>
                        </Border>

                        <!-- Wordmark -->
                        <TextBlock Foreground="White" FontSize="30" FontWeight="Bold"
                                   HorizontalAlignment="Center" FontFamily="Segoe UI">
                            <Run Text="Daily"/><Run Text="Budget" Foreground="#6EE7A0"/>
                        </TextBlock>

                        <TextBlock Text="Gestão financeira pessoal" Foreground="#80C8A0" FontSize="12.5"
                                   FontWeight="Normal" HorizontalAlignment="Center" Margin="0,6,0,0"
                                   TextAlignment="Center" FontFamily="Segoe UI"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ RIGHT PANEL: LOGIN FORM ═══ -->
            <Grid x:Name="formPanel" Grid.Column="1" Margin="44,25,40,25" Opacity="0">
                <Grid.RowDefinitions>
                    <!-- TitleBar Controls -->
                    <RowDefinition Height="Auto"/>
                    <!-- Form content -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Window controls -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,-15,0">
                    <Button Content="─" Style="{DynamicResource EstiloTitleBar}" Foreground="#8E9E8E" Click="Minimize_Click"/>
                    <Button Content="✕" Style="{DynamicResource EstiloTitleBar}" Foreground="#8E9E8E" Click="Close_Click"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <!-- Welcome header -->
                        <TextBlock Foreground="White" FontSize="26" FontWeight="Black" Margin="0,0,0,28"
                                   FontFamily="Segoe UI, Inter" Text="Login"/>

                        <!-- Error panel -->
                        <Border x:Name="pnlErro" Visibility="Collapsed" CornerRadius="14" Padding="16,12" 
                                Margin="0,0,0,20" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#E74C3C" Opacity="0.08"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#E74C3C" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="26" Height="26" CornerRadius="7" Margin="0,0,10,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#E74C3C" Opacity="0.15"/>
                                    </Border.Background>
                                    <TextBlock Text="!" Foreground="#E74C3C" FontSize="14" FontWeight="Black" 
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="txtErro" Foreground="#F07070" FontSize="13" TextWrapping="Wrap" 
                                           VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- Email Label -->
                        <TextBlock Text="E-MAIL" Foreground="#8E9E8E" FontSize="10.5" FontWeight="Black" 
                                   Margin="6,0,0,8"/>
                        <!-- Email Input with focus border animation -->
                        <Border x:Name="borderEmail" Background="#07FFFFFF" CornerRadius="14" Height="50" 
                                Margin="0,0,0,20" BorderThickness="1.5">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.08"/>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="✉" FontSize="18" Foreground="#8E9E8E"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                <TextBox Grid.Column="1" x:Name="txtEmail" Background="Transparent" BorderThickness="0" 
                                         Foreground="{DynamicResource CorTexto}" Padding="5,0,15,0" 
                                         VerticalContentAlignment="Center" FontSize="14.5" 
                                         CaretBrush="{DynamicResource CorDestaque}" 
                                         SelectionBrush="{DynamicResource CorDestaque}"
                                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus"
                                         Tag="borderEmail"/>
                            </Grid>
                        </Border>

                        <!-- Password Label -->
                        <TextBlock Text="PALAVRA-PASSE" Foreground="#8E9E8E" FontSize="10.5" FontWeight="Black" 
                                   Margin="6,0,0,8"/>
                        <!-- Password Input -->
                        <Border x:Name="borderPassword" Background="#07FFFFFF" CornerRadius="14" Height="50" 
                                Margin="0,0,0,12" BorderThickness="1.5">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.08"/>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="🔑" FontSize="16" Foreground="#8E9E8E"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.75"/>
                                
                                <PasswordBox Grid.Column="1" x:Name="txtPassword" Background="Transparent" 
                                             BorderThickness="0" Foreground="{DynamicResource CorTexto}" 
                                             Padding="5,0,10,0" VerticalContentAlignment="Center" FontSize="14.5" 
                                             CaretBrush="{DynamicResource CorDestaque}"
                                             GotFocus="Input_GotFocus" LostFocus="Input_LostFocus"
                                             Tag="borderPassword" PasswordChanged="txtPassword_PasswordChanged"/>

                                <TextBox Grid.Column="1" x:Name="txtPasswordUnmasked" Background="Transparent" 
                                         BorderThickness="0" Foreground="{DynamicResource CorTexto}" 
                                         Padding="5,0,10,0" VerticalContentAlignment="Center" FontSize="14.5" 
                                         CaretBrush="{DynamicResource CorDestaque}"
                                         GotFocus="Input_GotFocus" LostFocus="Input_LostFocus"
                                         Tag="borderPassword" Visibility="Collapsed" TextChanged="txtPasswordUnmasked_TextChanged"/>

                                <ToggleButton Grid.Column="2" x:Name="btnShowPassword" Click="btnShowPassword_Click"
                                              Style="{StaticResource EstiloBotaoRevelarSenha}"/>
                            </Grid>
                        </Border>


                        <!-- Login button with gradient -->
                        <Button x:Name="btnLogin" Height="52" FontSize="15" Click="Login_Click" Cursor="Hand" 
                                BorderThickness="0" Foreground="White" Margin="0,10,0,18" FontWeight="Bold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="btnBorder" CornerRadius="14">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#1B8A3D" Offset="0"/>
                                                <GradientStop Color="#27AE60" Offset="0.5"/>
                                                <GradientStop Color="#2ECC71" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="20" Color="#27AE60" Opacity="0.3" ShadowDepth="0"/>
                                        </Border.Effect>
                                        <TextBlock Text="ENTRAR NA CONTA" FontSize="14.5" FontWeight="Bold" 
                                                   Foreground="White" HorizontalAlignment="Center" 
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="btnBorder" Property="Background">
                                                <Setter.Value>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                        <GradientStop Color="#219B49" Offset="0"/>
                                                        <GradientStop Color="#2ECC71" Offset="0.5"/>
                                                        <GradientStop Color="#45D98A" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="btnBorder" Property="Effect">
                                                <Setter.Value>
                                                    <DropShadowEffect BlurRadius="28" Color="#27AE60" Opacity="0.45" ShadowDepth="0"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="btnBorder" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter TargetName="btnBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Divider -->
                        <Grid Margin="0,0,0,18" Height="20">
                            <Rectangle Height="1" VerticalAlignment="Center" Opacity="0.15">
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="White" Offset="0.5"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>
                            <Border HorizontalAlignment="Center" Padding="18,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#0D100D" Offset="0"/>
                                        <GradientStop Color="#111611" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="ou" Foreground="#8E9E8E" FontSize="12" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <!-- Google button -->
                        <Button x:Name="btnGoogle" Content="Continuar com Google" Style="{StaticResource EstiloGoogle}" 
                                Click="btnGoogle_Click" Height="50" Margin="0,0,0,26"/>

                        <!-- Register link -->
                        <Border CornerRadius="14" Padding="16,12" BorderThickness="1">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.03"/>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.05"/>
                            </Border.BorderBrush>
                            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                <TextBlock Text="Não tens conta?" Foreground="#8E9E8E" FontSize="13" 
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontWeight="Medium"/>
                                <Button Content="Cria uma gratuitamente →" Background="Transparent" BorderThickness="0" 
                                        Foreground="#2ECC71" FontWeight="Bold" FontSize="14" Click="Register_Click" 
                                        Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Border>
</Window>
