<UserControl x:Class="DailyBudgetWPF.Vistas.ListaDesejos"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="800" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="Transparent" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Border CornerRadius="22" Margin="0,0,0,25" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1A2ECC71" Offset="0"/>
                        <GradientStop Color="#0D3498DB" Offset="0.5"/>
                        <GradientStop Color="#1A6C5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#2ECC71" Offset="0"/>
                        <GradientStop Color="#3498DB" Offset="0.5"/>
                        <GradientStop Color="#6C5CE7" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Grid Margin="30,22">
                     <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎯 Lista de Desejos" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource CorTexto}"/>
                            <ToggleButton x:Name="btnAjudaDesejos" Style="{DynamicResource EstiloBotaoAjuda}" Margin="12,0,0,0"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaDesejos}" StaysOpen="False" AllowsTransparency="True"
                                   PlacementTarget="{Binding ElementName=btnAjudaDesejos}" Placement="Bottom">
                                <Border Background="#141c24" BorderBrush="#3498DB" BorderThickness="1.5" CornerRadius="14" Padding="18,14" MaxWidth="300">
                                    <Border.Effect><DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="🎯 Lista de Desejos" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                                        <TextBlock TextWrapping="Wrap" Foreground="#B0C8D8" FontSize="12.5" LineHeight="20">
                                            A Lista de Desejos serve para planeares as tuas próximas compras (ex: um telemóvel, uma viagem).
                                            A aplicação compara o preço do item com o teu saldo disponível e mostra uma barra de progresso com a percentagem que já tens poupada para o comprar!
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                        <TextBlock Text="Planeia as tuas compras futuras e acompanha o teu progresso de poupança" 
                                   Foreground="{DynamicResource CorTextoSec}" FontSize="14" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cards de resumo -->
            <Grid Grid.Row="1" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card: Saldo Disponível -->
                <Border Grid.Column="0" Background="{DynamicResource CorCard}" CornerRadius="18" Padding="20,18" Margin="0,0,10,0"
                        BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="SALDO DISPONÍVEL" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtSaldoResumo" Text="0.00 €" Foreground="#2ECC71" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="14" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A2ECC71" Offset="0"/>
                                    <GradientStop Color="#0D2ECC71" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="💰" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Progresso -->
                <Border Grid.Column="1" Background="{DynamicResource CorCard}" CornerRadius="18" Padding="20,18" Margin="5,0"
                        BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="DESEJOS REALIZADOS" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtAdquiridosResumo" Text="0 / 0" Foreground="#3498DB" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="14" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1A3498DB" Offset="0"/>
                                    <GradientStop Color="#0D3498DB" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🏆" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Card: Falta Poupar -->
                <Border Grid.Column="2" Background="{DynamicResource CorCard}" CornerRadius="18" Padding="20,18" Margin="10,0,0,0"
                        BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="12" Color="#000000" Opacity="0.1" ShadowDepth="2"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="VALOR TOTAL DESEJADO" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="0,0,0,8"/>
                            <TextBlock x:Name="txtFaltaPouparResumo" Text="0.00 €" Foreground="#E74C3C" FontSize="24" FontWeight="Bold"/>
                        </StackPanel>
                        <Border Grid.Column="1" Width="48" Height="48" CornerRadius="14" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1AE74C3C" Offset="0"/>
                                    <GradientStop Color="#0DE74C3C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="🛒" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- Formulário para adicionar novo item -->
            <Border Grid.Row="2" Background="{DynamicResource CorCard}" Padding="25,20" CornerRadius="20"
                    Margin="0,0,0,20" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" Color="#000000" Opacity="0.08" ShadowDepth="1"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="ITEM / PRODUTO" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,6"/>
                        <TextBox Style="{DynamicResource EstiloInput}" x:Name="txtItem" Height="44"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="PREÇO EST. (€)" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,6"/>
                        <TextBox Style="{DynamicResource EstiloInput}" x:Name="txtPreco" Height="44" TextAlignment="Right" LostFocus="txtPreco_LostFocus"/>
                    </StackPanel>

                    <Button x:Name="btnAdicionarItem" Grid.Column="2" Content="+ ADICIONAR"
                            Style="{DynamicResource EstiloBotao}" VerticalAlignment="Bottom"
                            Height="44" Padding="25,0" Click="btnAdicionarItem_Click"/>
                </Grid>
            </Border>

            <!-- Lista de itens da wishlist -->
            <Grid Grid.Row="3">
                <!-- Estado vazio -->
                <Border x:Name="bordEstadoVazio" Background="{DynamicResource CorCard}" CornerRadius="22"
                        BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2" Visibility="Collapsed"
                        MinHeight="250">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                    </StackPanel>
                </Border>

                <!-- Lista de itens -->
                <Border x:Name="bordListaItens" Background="{DynamicResource CorCard}" CornerRadius="22"
                        BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                         <!-- Header da secção -->
                        <Grid Margin="25,20,25,5">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="OS TEUS DESEJOS" Foreground="{DynamicResource CorTextoSec}" FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="btnAjudaListaDesejos" Style="{DynamicResource EstiloBotaoAjuda}" Margin="8,0,0,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaListaDesejos}" StaysOpen="False" AllowsTransparency="True"
                                       PlacementTarget="{Binding ElementName=btnAjudaListaDesejos}" Placement="Bottom">
                                    <Border Background="#141c24" BorderBrush="#3498DB" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="280">
                                        <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                        <TextBlock TextWrapping="Wrap" Foreground="#B0C8D8" FontSize="12.5" LineHeight="20">
                                            Quando poupares o suficiente para comprar um item, podes clicar em <Run FontWeight="Bold" Foreground="#2ECC71">✓ Comprado</Run> para registá-lo automaticamente como despesa e tirá-lo da lista de desejos.
                                        </TextBlock>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="txtContador" Text="0 itens" Foreground="{DynamicResource CorTextoSec}" FontSize="12" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                            <ItemsControl x:Name="icWishlist" Margin="12,5,12,15">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="6" Width="255" MinHeight="185">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource CorFundo}"/>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource CorBorda}"/>
                                                    <Setter Property="BorderThickness" Value="1.2"/>
                                                    <Setter Property="CornerRadius" Value="18"/>
                                                    <Setter Property="Padding" Value="18"/>
                                                    <Setter Property="Effect">
                                                        <Setter.Value>
                                                            <DropShadowEffect BlurRadius="10" Color="#000000" Opacity="0.1" ShadowDepth="2"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource CorDestaque}"/>
                                                            <Setter Property="Effect">
                                                                <Setter.Value>
                                                                    <DropShadowEffect BlurRadius="18" Color="#2ECC71" Opacity="0.2" ShadowDepth="3"/>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding Adquirido}" Value="True">
                                                            <Setter Property="Opacity" Value="0.65"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Topo: estado -->
                                                <Grid Margin="0,0,0,10">
                                                    <TextBlock Text="{Binding StatusIcone}" FontSize="18" HorizontalAlignment="Right"/>
                                                </Grid>

                                                <!-- Nome do item -->
                                                <StackPanel Grid.Row="1" Margin="0,0,0,12">
                                                    <TextBlock Text="{Binding Item}" Foreground="{DynamicResource CorTexto}"
                                                               FontSize="17" FontWeight="Bold" TextWrapping="Wrap" 
                                                               TextTrimming="CharacterEllipsis" MaxHeight="46"/>
                                                    <TextBlock Text="{Binding ValorEstimado, StringFormat={}{0:N2} €}"
                                                               FontSize="22" FontWeight="Bold" Margin="0,5,0,0">
                                                        <TextBlock.Foreground>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                <GradientStop Color="#2ECC71" Offset="0"/>
                                                                <GradientStop Color="#3498DB" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </TextBlock.Foreground>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- Barra de progresso premium -->
                                                <StackPanel Grid.Row="2" Margin="0,0,0,12">
                                                    <Grid Margin="0,0,0,5">
                                                        <TextBlock Text="Poupança" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding TextoProgresso}" Foreground="{Binding CorProgresso}"
                                                                   FontSize="10" FontWeight="Bold" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                    <!-- Track da barra -->
                                                    <Border Height="8" CornerRadius="4" Background="#12FFFFFF">
                                                        <Border CornerRadius="4" HorizontalAlignment="Left"
                                                                Width="{Binding LarguraBarra}">
                                                            <Border.Background>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#2ECC71" Offset="0"/>
                                                                    <GradientStop Color="#3498DB" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                        </Border>
                                                    </Border>
                                                    <TextBlock Text="{Binding TextoPercentagem}" Foreground="{Binding CorProgresso}"
                                                               FontSize="10" FontWeight="SemiBold" Margin="0,4,0,0" HorizontalAlignment="Right"/>
                                                </StackPanel>

                                                <!-- Botões de ação -->
                                                <Grid Grid.Row="3">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Background="Transparent" Foreground="#2ECC71"
                                                                BorderThickness="0" FontSize="14" Cursor="Hand" 
                                                                Margin="0,0,5,0" Padding="8,5"
                                                                Click="btnDone_Click" Tag="{Binding}"
                                                                ToolTip="Marcar como adquirido">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                                    <TextBlock Text="✓ Comprado" FontSize="11" FontWeight="Bold" 
                                                                                               Foreground="#2ECC71" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="bg" Property="Background" Value="#152ECC71"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                        <Button Click="btnRemoverItem_Click" Tag="{Binding Id}"
                                                                ToolTip="Remover item">
                                                            <Button.Style>
                                                                <Style TargetType="Button">
                                                                    <Setter Property="Cursor" Value="Hand"/>
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="Button">
                                                                                <Border x:Name="bg" Background="Transparent" CornerRadius="8" Padding="8,5">
                                                                                    <TextBlock Text="🗑" FontSize="13" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="bg" Property="Background" Value="#15E74C3C"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</UserControl>
