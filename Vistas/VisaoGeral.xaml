<UserControl x:Class="DailyBudgetWPF.Vistas.VisaoGeral"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" d:DesignHeight="900" d:DesignWidth="1000">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="Transparent" Margin="35">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="280"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Linha 0: Cards de totais com tendência -->
            <UniformGrid Grid.Row="0" Rows="1" Columns="3" Margin="0,0,0,25">

                <!-- Card Saldo -->
                <Border Background="{DynamicResource CorCard}" Margin="0,0,15,0" CornerRadius="20"
                        Padding="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                    <Grid>
                        <TextBlock Text="💰" FontSize="42" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Foreground="White" Opacity="0.12" Margin="0,0,-5,0"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="SALDO DISPONÍVEL" Foreground="{DynamicResource CorTextoSec}"
                                           FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="btnAjudaSaldo" Style="{DynamicResource EstiloBotaoAjuda}" Margin="8,0,0,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaSaldo}" StaysOpen="False" AllowsTransparency="True"
                                       PlacementTarget="{Binding ElementName=btnAjudaSaldo}" Placement="Bottom">
                                    <Border Background="#1A2820" BorderBrush="#27AE60" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="260">
                                        <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                        <TextBlock TextWrapping="Wrap" Foreground="#B0C8B0" FontSize="12.5" LineHeight="19">
                                            O teu <Run FontWeight="Bold" Foreground="White">saldo atual</Run> é a diferença entre todas as receitas e todas as despesas registadas. Quanto maior, melhor!
                                        </TextBlock>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <TextBlock x:Name="txtSaldoGrande" Text="0,00 €" FontSize="34"
                                       FontWeight="Bold" Foreground="{DynamicResource CorTexto}"/>
                            <TextBlock x:Name="txtTendenciaSaldo" Text="" FontSize="11"
                                       Foreground="{DynamicResource CorTextoSec}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card Receitas -->
                <Border Background="{DynamicResource CorCard}" Margin="0,0,15,0" CornerRadius="20"
                        Padding="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                    <Grid>
                        <TextBlock Text="📈" FontSize="42" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Foreground="White" Opacity="0.12" Margin="0,0,-5,0"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="TOTAL RECEITAS" Foreground="{DynamicResource CorTextoSec}"
                                           FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="btnAjudaReceitas" Style="{DynamicResource EstiloBotaoAjuda}" Margin="8,0,0,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaReceitas}" StaysOpen="False" AllowsTransparency="True"
                                       PlacementTarget="{Binding ElementName=btnAjudaReceitas}" Placement="Bottom">
                                    <Border Background="#1A2820" BorderBrush="#2ECC71" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="260">
                                        <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                        <TextBlock TextWrapping="Wrap" Foreground="#B0C8B0" FontSize="12.5" LineHeight="19">
                                            Soma de todo o dinheiro que <Run FontWeight="Bold" Foreground="#2ECC71">entrou</Run> na tua conta (salários, extras, etc.). Vai a <Run FontWeight="Bold" Foreground="White">➕ Receitas</Run> para adicionar.
                                        </TextBlock>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <TextBlock x:Name="txtReceitasDashboard" Text="0,00 €" FontSize="34"
                                       FontWeight="Bold" Foreground="#2ECC71"/>
                            <TextBlock x:Name="txtTendenciaReceitas" Text="" FontSize="11"
                                       Foreground="{DynamicResource CorTextoSec}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Card Despesas -->
                <Border Background="{DynamicResource CorCard}" CornerRadius="20"
                        Padding="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                    <Grid>
                        <TextBlock Text="📉" FontSize="42" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Foreground="White" Opacity="0.12" Margin="0,0,-5,0"/>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="TOTAL DESPESAS" Foreground="{DynamicResource CorTextoSec}"
                                           FontSize="11" FontWeight="Black" VerticalAlignment="Center"/>
                                <ToggleButton x:Name="btnAjudaDespesas" Style="{DynamicResource EstiloBotaoAjuda}" Margin="8,0,0,0"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaDespesas}" StaysOpen="False" AllowsTransparency="True"
                                       PlacementTarget="{Binding ElementName=btnAjudaDespesas}" Placement="Bottom">
                                    <Border Background="#201518" BorderBrush="#E74C3C" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="260">
                                        <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                        <TextBlock TextWrapping="Wrap" Foreground="#C8B0B0" FontSize="12.5" LineHeight="19">
                                            Soma de todo o dinheiro que <Run FontWeight="Bold" Foreground="#E74C3C">saiu</Run> da tua conta. Vai a <Run FontWeight="Bold" Foreground="White">➖ Despesas</Run> para gerir os teus gastos.
                                        </TextBlock>
                                    </Border>
                                </Popup>
                            </StackPanel>
                            <TextBlock x:Name="txtDespesasDashboard" Text="0,00 €" FontSize="34"
                                       FontWeight="Bold" Foreground="#E74C3C"/>
                            <TextBlock x:Name="txtTendenciaDespesas" Text="" FontSize="11"
                                       Foreground="{DynamicResource CorTextoSec}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- Linha 1: Gráfico de balanço -->
            <Border Grid.Row="1" Background="{DynamicResource CorCard}" Margin="0,0,0,20"
                    CornerRadius="25" Padding="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="10,0,0,15">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Análise de Balanço Acumulado" Foreground="{DynamicResource CorTexto}"
                                       FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <ToggleButton x:Name="btnAjudaGrafico" Style="{DynamicResource EstiloBotaoAjuda}" Margin="10,0,0,0"/>
                            <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaGrafico}" StaysOpen="False" AllowsTransparency="True"
                                   PlacementTarget="{Binding ElementName=btnAjudaGrafico}" Placement="Bottom">
                                <Border Background="#1A2820" BorderBrush="#27AE60" BorderThickness="1.5" CornerRadius="12" Padding="16,12" MaxWidth="280">
                                    <Border.Effect><DropShadowEffect BlurRadius="18" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                    <TextBlock TextWrapping="Wrap" Foreground="#B0C8B0" FontSize="12.5" LineHeight="19">
                                        Este gráfico mostra a evolução do teu <Run FontWeight="Bold" Foreground="White">balanço</Run> ao longo dos meses.
                                        Usa os botões 📈 LINHAS ou 📊 BARRAS para mudar o tipo de vista.
                                    </TextBlock>
                                </Border>
                            </Popup>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnLine" Content="📈 LINHAS" Style="{DynamicResource EstiloBotao}"
                                    Padding="15,5" FontSize="11" Click="btnChartType_Click" Tag="Line" Margin="0,0,8,0"/>
                            <Button x:Name="btnBar"  Content="📊 BARRAS" Style="{DynamicResource EstiloBotao}"
                                    Background="#34495E" Padding="15,5" FontSize="11" Click="btnChartType_Click" Tag="Bar"/>
                        </StackPanel>
                    </Grid>
                    <lvc:CartesianChart x:Name="chartPatrimonio" Grid.Row="1" Hoverable="False" AnimationsSpeed="0:0:0.5">
                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis x:Name="axisX" Foreground="{DynamicResource CorTextoSec}" ShowLabels="True"/>
                        </lvc:CartesianChart.AxisX>
                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis Title="Valor (€)" Foreground="{DynamicResource CorTextoSec}"/>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>
                </Grid>
            </Border>

            <!-- Linha 2: Alertas de orçamento -->
            <Border x:Name="bordAlertas" Grid.Row="2" Background="#1A0A00" CornerRadius="16"
                    Margin="0,0,0,20" Padding="20,15" BorderBrush="#E74C3C" BorderThickness="1.5"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⚠️ Alertas de Orçamento — Categorias em risco este mês"
                               Foreground="#E74C3C" FontSize="14" FontWeight="Bold" Margin="0,0,0,12"/>
                    <ItemsControl x:Name="icAlertas" Grid.Row="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0D0D0D" CornerRadius="12" Margin="0,0,12,0"
                                        Padding="15,10" BorderBrush="{Binding CorEstado}" BorderThickness="1.5" MinWidth="180">
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource CorTexto}" FontWeight="Bold" FontSize="14">
                                            <Run Text="{Binding EmojiCategoria}"/>
                                            <Run Text=" "/>
                                            <Run Text="{Binding NomeCategoria}"/>
                                        </TextBlock>
                                        <ProgressBar Value="{Binding Percentagem, Mode=OneWay}" Maximum="100" Height="6"
                                                     Foreground="{Binding CorEstado}" Background="#1A1A2E"
                                                     BorderThickness="0" Margin="0,6,0,4"/>
                                        <TextBlock Text="{Binding TextoEstado}" Foreground="{Binding CorEstado}"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                        <TextBlock Foreground="#888888" FontSize="10" Margin="0,2,0,0">
                                            <Run Text="{Binding GastoMesAtual, StringFormat={}{0:N2} €}"/>
                                            <Run Text=" / "/>
                                            <Run Text="{Binding LimiteMensal, StringFormat={}{0:N2} €}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Linha 3: Historial de transações com data -->
            <Border Grid.Row="3" Background="{DynamicResource CorCard}" CornerRadius="25"
                    BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,20">
                        <TextBlock Text="Histórico de Transações" Foreground="{DynamicResource CorTexto}"
                                   FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="btnAddReceita" Style="{DynamicResource EstiloBotao}"
                                    Content="+ RECEITA" Width="120" Height="38" Margin="0,0,10,0"
                                    Click="btnAddReceita_Click"/>
                            <Button x:Name="btnAddDespesa" Style="{DynamicResource EstiloBotao}"
                                    Background="#E74C3C" Content="- DESPESA" Width="120" Height="38"
                                    Click="btnAddDespesa_Click"/>
                        </StackPanel>
                    </Grid>
                    <ListBox Grid.Row="1" x:Name="lstAtividade" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource CorBorda}" BorderThickness="0,0,0,1" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Ícone da transação -->
                                        <Border Width="44" Height="44" Background="{Binding CorValor}" CornerRadius="13">
                                            <TextBlock Text="{Binding Icone}" FontSize="20" Foreground="White"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Descrição + Categoria -->
                                        <StackPanel Grid.Column="1" Margin="18,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Descricao}" Foreground="{DynamicResource CorTexto}"
                                                       FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="{Binding Categoria}" Foreground="{DynamicResource CorTextoSec}"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <!-- Valor + Data -->
                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Valor, StringFormat='{}{0:N2} €'}"
                                                       Foreground="{Binding CorValor}" FontSize="17"
                                                       FontWeight="Bold" HorizontalAlignment="Right"/>
                                            <TextBlock Text="{Binding Data, StringFormat=dd MMM yyyy}"
                                                       Foreground="{DynamicResource CorTextoSec}"
                                                       FontSize="11" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
