<UserControl x:Class="DailyBudgetWPF.Vistas.Receitas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             mc:Ignorable="d" d:DesignHeight="750" d:DesignWidth="1000"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Grid Background="Transparent" Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border CornerRadius="22" Margin="0,0,0,25" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A2ECC71" Offset="0"/>
                    <GradientStop Color="#0D27AE60" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2ECC71" Offset="0"/>
                    <GradientStop Color="#27AE60" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Grid Margin="30,22">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="➕ Entrada de Receitas" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource CorTexto}"/>
                        <ToggleButton x:Name="btnAjudaReceitas" Style="{DynamicResource EstiloBotaoAjuda}" Margin="12,0,0,0"/>
                        <Popup IsOpen="{Binding IsChecked, ElementName=btnAjudaReceitas}" StaysOpen="False" AllowsTransparency="True"
                               PlacementTarget="{Binding ElementName=btnAjudaReceitas}" Placement="Bottom">
                            <Border Background="#1A2820" BorderBrush="#2ECC71" BorderThickness="1.5" CornerRadius="14" Padding="18,14" MaxWidth="300">
                                <Border.Effect><DropShadowEffect BlurRadius="20" Color="#000000" Opacity="0.5" ShadowDepth="0"/></Border.Effect>
                                <StackPanel>
                                    <TextBlock Text="➕ Receitas" FontWeight="Bold" Foreground="White" FontSize="14" Margin="0,0,0,8"/>
                                    <TextBlock TextWrapping="Wrap" Foreground="#B0C8B0" FontSize="12.5" LineHeight="20">
                                        Aqui registas todo o dinheiro que <Run FontWeight="Bold" Foreground="#2ECC71">entra</Run> na tua conta.
                                        Preenche a descrição (ex: &quot;Salário&quot;), o valor e a data, e clica em REGISTAR.
                                        Podes filtrar por datas e editar ou apagar entradas na tabela.
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </StackPanel>
                    <TextBlock Text="Regista os teus ganhos e aumentos de saldo" Foreground="{DynamicResource CorTextoSec}" FontSize="14" Margin="0,5,0,0"/>
                </StackPanel>
                <TextBlock Text="💰" FontSize="40" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="White" Opacity="0.12"/>
            </Grid>
        </Border>

        <!-- Formulário de inserção / edição -->
        <Border Grid.Row="1" Background="{DynamicResource CorCard}" Padding="25" CornerRadius="25" Margin="0,0,0,15" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="DESCRIÇÃO" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                    <TextBox Style="{DynamicResource EstiloInput}" x:Name="txtDescricao" Height="45" Tag="Ex: Salário, Venda..."/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="VALOR (€)" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                    <TextBox Style="{DynamicResource EstiloInput}" x:Name="txtValor" Height="45" TextAlignment="Right" LostFocus="txtValor_LostFocus"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="DATA" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" Margin="5,0,0,8"/>
                    <DatePicker x:Name="dpData" Height="45" Style="{DynamicResource EstiloDatePicker}"/>
                </StackPanel>

                <Button x:Name="btnGuardar" Grid.Column="3" Content="REGISTAR" Style="{DynamicResource EstiloBotao}"
                        Padding="25,0" Height="45" VerticalAlignment="Bottom" Margin="0,0,8,0" Click="btnGuardar_Click"/>

                <Button x:Name="btnCancelar" Grid.Column="4" Content="✕ CANCELAR"
                        Background="#E74C3C" Foreground="White" BorderThickness="0"
                        Padding="15,0" Height="45" VerticalAlignment="Bottom" Cursor="Hand"
                        Visibility="Collapsed" Click="btnCancelar_Click"/>
            </Grid>
        </Border>

        <!-- Lista de receitas com botões Editar e Remover -->
        <Border Grid.Row="2" Background="{DynamicResource CorCard}" CornerRadius="25" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Filtro por data -->
                <Border Grid.Row="0" Background="#07FFFFFF" BorderBrush="{DynamicResource CorBorda}" BorderThickness="0,0,0,1" Padding="20,12">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="FILTRAR POR DATA" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <DatePicker x:Name="dpFiltro" Style="{DynamicResource EstiloDatePicker}" Height="36" Width="160"
                                    SelectedDateChanged="dpFiltro_SelectedDateChanged"/>
                        <Button Content="✕ Limpar" Click="btnLimparFiltro_Click"
                                Background="Transparent" Foreground="{DynamicResource CorTextoSec}" BorderThickness="1"
                                BorderBrush="{DynamicResource CorBorda}" Padding="10,0" Height="36" Margin="10,0,0,0"
                                Cursor="Hand" FontSize="12"/>
                        <TextBlock x:Name="txtResultadoFiltro" Foreground="{DynamicResource CorTextoSec}" FontSize="12"
                                   VerticalAlignment="Center" Margin="16,0,0,0"/>
                    </StackPanel>
                </Border>

                <DataGrid x:Name="dgReceitas" Grid.Row="1" Style="{DynamicResource EstiloDataGrid}" AutoGenerateColumns="False" IsReadOnly="True" Margin="20">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="DATA" Binding="{Binding Data, StringFormat=dd/MM/yyyy}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource CorTexto}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="DESCRIÇÃO" Binding="{Binding Descricao}" Width="*">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource CorTexto}"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="VALOR" Binding="{Binding Valor, StringFormat={}{0:N2} €}" Width="130">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#2ECC71"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="60" Header="✏️">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="✏️" Click="btnEditar_Click"
                                        Background="Transparent" BorderThickness="0"
                                        FontSize="14" Cursor="Hand" ToolTip="Editar"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Width="60" Header="🗑">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="🗑" Click="btnRemover_Click" Tag="{Binding Id}"
                                        Style="{DynamicResource EstiloBotaoRemover}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
