<Window x:Class="DailyBudgetWPF.Vistas.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DailyBudget" Height="800" Width="1300"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen">
    <Border Background="{DynamicResource CorFundo}" CornerRadius="30" BorderBrush="{DynamicResource CorBorda}" BorderThickness="1.5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.Resources>
                <Storyboard x:Key="FadeInAnimation">
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.Y)" From="30" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>

            <Border Grid.Column="0" Background="{DynamicResource CorSidebar}" CornerRadius="30,0,0,30" BorderBrush="{DynamicResource CorBorda}" BorderThickness="0,0,1,0">
                <Grid Margin="20,40">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,40">
                        <Border Width="45" Height="45" Background="{DynamicResource CorDestaque}" CornerRadius="12">
                            <TextBlock Text="DB" Foreground="White" FontWeight="Bold" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="DailyBudget" Foreground="{DynamicResource CorTexto}" FontSize="24" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Row="1" Background="{DynamicResource CorFundo}" CornerRadius="20" Padding="15" Margin="0,0,0,40">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="50" Height="50" CornerRadius="25" Background="{DynamicResource CorDestaque}">
                                <TextBlock x:Name="txtIniciais" Text="?" FontSize="18" FontWeight="Bold"
                                           Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="15,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtUserName" Text="UTILIZADOR" Foreground="{DynamicResource CorTexto}" FontWeight="Bold" FontSize="14"/>
                                <TextBlock x:Name="txtUserUsername" Text="@utilizador" Foreground="{DynamicResource CorTextoSec}" FontSize="12"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" IsChecked="True" Click="NavDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#3498DB" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Visão Geral" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" Click="NavReceitas_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📈" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#2ECC71" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Receitas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" Click="NavDespesas_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📉" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#E74C3C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Despesas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" Click="NavCategorias_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏷️" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#9B59B6" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Categorias" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <Separator Background="{DynamicResource CorBorda}" Margin="0,15"/>
                        <TextBlock Text="OPÇÕES" Foreground="{DynamicResource CorTextoSec}" FontSize="10" FontWeight="Bold" Margin="15,0,0,10"/>
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" Click="NavRelatorios_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📂" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#3498DB" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Relatórios" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{DynamicResource EstiloNavRadio}" Click="NavWishlist_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎯" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#E74C3C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Desejos" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>

                    <StackPanel Grid.Row="3">
                        <Button x:Name="btnToggleTema" Style="{DynamicResource EstiloNav}" Click="ToggleTheme_Click" Margin="0,0,0,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌙" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#F1C40F" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Alternar Tema" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{DynamicResource EstiloNav}" Click="Logout_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚪" FontFamily="Segoe UI Emoji" FontSize="16" Foreground="#E74C3C" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Sair" Foreground="#E74C3C" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="30,25">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="—" Click="Minimize_Click" Style="{DynamicResource EstiloTitleBar}"/>
                        <Button Content="✕" Click="Close_Click" Style="{DynamicResource EstiloTitleBar}" Foreground="#E74C3C"/>
                    </StackPanel>
                </Grid>

                <ContentControl Grid.Row="1" x:Name="ActiveContent">
                    <ContentControl.RenderTransform>
                        <TranslateTransform Y="0"/>
                    </ContentControl.RenderTransform>
                </ContentControl>
            </Grid>
        </Grid>
    </Border>
</Window>
