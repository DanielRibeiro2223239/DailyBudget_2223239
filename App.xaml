<Application x:Class="DailyBudgetWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Vistas/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Temas/TemaEscuro.xaml"/>
                <ResourceDictionary Source="Temas/Estilos.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            
            <Style TargetType="{x:Type Control}">
                <Setter Property="FontFamily" Value="Segoe UI, Roboto, Arial"/>
            </Style>
            <Style TargetType="{x:Type TextBlock}">
                <Setter Property="FontFamily" Value="Segoe UI, Roboto, Arial"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
