<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Color x:Key="Color_Fundo">#F5F7F5</Color>
    <Color x:Key="Color_Card">#FFFFFF</Color>
    <Color x:Key="Color_Borda">#E0E5E0</Color>
    <Color x:Key="Color_TextoPrim">#1A1A1A</Color>
    <Color x:Key="Color_TextoSec">#666666</Color>
    <Color x:Key="Color_Destaque">#27AE60</Color>
    <Color x:Key="Color_DestaqueHover">#1E8449</Color>
    <Color x:Key="Color_Sidebar">#FFFFFF</Color>

    <SolidColorBrush x:Key="CorFundo" Color="{StaticResource Color_Fundo}"/>
    <SolidColorBrush x:Key="CorCard" Color="{StaticResource Color_Card}" Opacity="0.85"/>
    <SolidColorBrush x:Key="CorBorda" Color="{StaticResource Color_Borda}"/>
    <SolidColorBrush x:Key="CorTexto" Color="{StaticResource Color_TextoPrim}"/>
    <SolidColorBrush x:Key="CorTextoSec" Color="{StaticResource Color_TextoSec}"/>
    <SolidColorBrush x:Key="CorDestaque" Color="{StaticResource Color_Destaque}"/>
    <SolidColorBrush x:Key="CorDestaqueHover" Color="{StaticResource Color_DestaqueHover}"/>
    <SolidColorBrush x:Key="CorSidebar" Color="{StaticResource Color_Sidebar}" Opacity="0.7"/>
</ResourceDictionary>





