<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
            <Color x:Key="Color_Fundo">#0B0E0B</Color>
    <Color x:Key="Color_Card">#141914</Color>
    <Color x:Key="Color_Borda">#222B22</Color>
    <Color x:Key="Color_TextoPrim">#FFFFFF</Color>
    <Color x:Key="Color_TextoSec">#8E9E8E</Color>
    <Color x:Key="Color_Destaque">#2ECC71</Color>
    <Color x:Key="Color_DestaqueHover">#40D47E</Color>
    <Color x:Key="Color_Sidebar">#0F130F</Color>

    <SolidColorBrush x:Key="CorFundo" Color="{StaticResource Color_Fundo}"/>
    <SolidColorBrush x:Key="CorCard" Color="{StaticResource Color_Card}" Opacity="0.85"/>
    <SolidColorBrush x:Key="CorBorda" Color="{StaticResource Color_Borda}"/>
    <SolidColorBrush x:Key="CorTexto" Color="{StaticResource Color_TextoPrim}"/>
    <SolidColorBrush x:Key="CorTextoSec" Color="{StaticResource Color_TextoSec}"/>
    <SolidColorBrush x:Key="CorDestaque" Color="{StaticResource Color_Destaque}"/>
    <SolidColorBrush x:Key="CorDestaqueHover" Color="{StaticResource Color_DestaqueHover}"/>
    <SolidColorBrush x:Key="CorSidebar" Color="{StaticResource Color_Sidebar}" Opacity="0.6"/>
</ResourceDictionary>





